rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: only the owner or admin can read/write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Requests collection
    match /requests/{requestId} {
      // Anyone authenticated can read tickets from their own division, admins see all
      allow read: if request.auth != null && (
        isAdmin() ||
        resource.data.division == getUserDivision()
      );

      // Any authenticated user can create a ticket
      allow create: if request.auth != null;

      // Only admins can update / delete
      allow update, delete: if request.auth != null && isAdmin();
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function getUserDivision() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.division;
    }
  }
}
