rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Reference uploads (anyone authenticated)
    match /references/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 20 * 1024 * 1024;
    }

    // Final deliverables (authenticated users can read, only admin can write)
    match /finals/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Brand assets (authenticated users can read, only admin can upload)
    match /brand-assets/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 100 * 1024 * 1024;
    }
  }
}
